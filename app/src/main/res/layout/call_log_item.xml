<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:elevation="4dp"
    android:layout_margin="4dp"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <!-- Icon Section -->
    <FrameLayout
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="12dp"
        android:background="@drawable/circle_background"
        android:elevation="4dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/default_contact_icon"
            android:layout_gravity="center"
            android:scaleType="centerCrop" />
    </FrameLayout>

    <!-- Text Section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="John Doe (5)"
            android:textSize="16dp"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/contact_phone_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="123-456-7890"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Toggle Section -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="8dp">

        <!-- Block/Unblock Toggle -->
        <Switch
            android:id="@+id/contact_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textOff="Unblock"
            android:textOn="Block"
            android:checked="false"
            tools:ignore="UseSwitchCompatOrMaterialXml" />

        <!-- Block Text (Changes between Block and Unblock) -->
<!--        <TextView
            android:id="@+id/contact_blocked_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Block"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>-->
    </LinearLayout>
</LinearLayout>









