<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingBottom="8dp"
    android:fitsSystemWindows="true">

    <!-- Search Bar -->
    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="4dp"
        android:padding="5dp"
        >

        <!-- EditText with rounded corners -->
        <!--
                <EditText
                    android:id="@+id/searchBar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_alignParentLeft="true"
                    android:layout_toLeftOf="@id/clearButton"
                    android:hint="🔍 Find Friends"
                    android:paddingLeft="12dp"
                    android:textColor="@color/black"
                    android:background="@drawable/search_bar_background" /> &lt;!&ndash; Set custom background &ndash;&gt;
        -->
        <EditText
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentLeft="true"
            android:hint="🔍 Search"
            android:paddingLeft="12dp"
            android:textColor="@color/black"
            android:textColorHint="#4B4B4B"
            android:background="@drawable/search_bar_background"
            android:imeOptions="actionSearch"
            android:inputType="text" /> <!-- Make sure it's set to text -->

        <!-- Clear Button -->
        <ImageView
            android:id="@+id/clearButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:padding="5dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:visibility="gone" />
    </RelativeLayout>
    <!-- LinearLayout containing Followers and Following headings -->
    <LinearLayout
        android:id="@+id/contactsLayout"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Username Heading -->

        <!-- Follower Heading -->
        <TextView
            android:id="@+id/followersHeading"
            android:layout_width="167dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="Follower"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Following Heading -->
        <TextView
            android:id="@+id/followingHeading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Following"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_weight="1" />
    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/instagram_contacts_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:ignore="MissingConstraints" />
</LinearLayout>





