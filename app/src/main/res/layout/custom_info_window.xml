<!-- res/layout/info_window.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp"
    android:background="@drawable/info_window_background"
    android:layout_gravity="center">

    <TextView
        android:id="@+id/info_window_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:padding="2dp"
        android:text="Recent Location"/>

    <TextView
        android:id="@+id/info_window_address"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textSize="14sp"
        android:ellipsize="end"
        android:singleLine="true"
        android:maxLines="1"
        android:text="Address will be here"/>

    <TextView
        android:id="@+id/info_window_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textSize="12sp"
        android:text="Time will be here"/>
</LinearLayout>










