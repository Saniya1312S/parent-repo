<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:fitsSystemWindows="true">

    <!-- Call Type Icon (left side) -->
    <ImageView
        android:id="@+id/call_type_icon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:contentDescription="Call Type Icon"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="16dp" />

    <!-- Vertical Layout for Duration and Call Type (below duration) -->
    <LinearLayout
        android:id="@+id/call_info_layout"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_toEndOf="@id/call_type_icon">

        <!-- Call Duration -->
        <TextView
            android:id="@+id/call_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:textColor="@color/black"/>

        <!-- Call Type (Incoming, Outgoing, Missed) -->
        <TextView
            android:id="@+id/call_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incoming"
            android:textSize="12sp"
            android:textColor="#DA424141" />
    </LinearLayout>

    <!-- RelativeLayout to Align Date/Time at the Right -->
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Call Date/Time (right side) -->
        <TextView
            android:id="@+id/call_date_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jan 1, 2025 10:00 AM"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>


</LinearLayout>
