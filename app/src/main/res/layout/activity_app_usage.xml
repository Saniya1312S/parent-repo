<LinearLayout android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- RecyclerView for Installed Apps -->
    <TextView
        android:text="Installed Apps"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"/>

    <!-- Message for no installed apps -->
    <TextView
        android:id="@+id/no_installed_apps_message"
        android:text="No installed app in last 24 hours"
        android:textSize="16sp"
        android:textColor="#FF0000"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/installed_apps_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- RecyclerView for Uninstalled Apps -->
    <TextView
        android:text="Uninstalled Apps"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"/>

    <!-- Message for no uninstalled apps -->
    <TextView
        android:id="@+id/no_uninstalled_apps_message"
        android:text="No uninstalled app in last 24 hours"
        android:textSize="16sp"
        android:textColor="#FF0000"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/uninstalled_apps_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- RecyclerView for App Usage -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="3dp"
        android:text="App Usage"
        android:textStyle="bold"
        android:textSize="18sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:layout_margin="2dp"
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>




