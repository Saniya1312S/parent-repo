<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:weightSum="3"
        android:paddingBottom="8dp"
        android:paddingTop="8dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_marginTop="16dp">

        <!-- Incoming Calls Card -->
        <LinearLayout
            android:id="@+id/incomingCallsClick"
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/rounded_background"
            android:elevation="2dp"
            android:layout_marginEnd="8dp">

            <!-- Incoming Text and Count -->
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="Incoming Calls"
                android:src="@drawable/ic_incoming_call" />

            <TextView
                    android:id="@+id/totalIncomingCalls"
                    android:text="1000"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>

        </LinearLayout>

        <!-- Outgoing Calls Card -->
        <LinearLayout
            android:id="@+id/outgoingCallsClick"
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/rounded_background"
            android:elevation="2dp"
            android:layout_marginEnd="8dp">
            <ImageView
                android:src="@drawable/ic_outgoing_call"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="Outgoing Calls" />
                <TextView
                    android:id="@+id/totalOutgoingCalls"
                    android:text="50"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>
        </LinearLayout>

        <!-- Missed Calls Card -->
        <LinearLayout
            android:id="@+id/missedCallsClick"
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/rounded_background"
            android:elevation="2dp">
            <ImageView
                android:src="@drawable/ic_missed_call"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="Missed Calls" />
              <TextView
                    android:id="@+id/totalMissedCalls"
                    android:text="30"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>
        </LinearLayout>

    </LinearLayout>


    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#e0e0e0"
        android:layout_marginBottom="8dp"/>

    <!-- RecyclerView for Call History -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call History"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>
</LinearLayout>












