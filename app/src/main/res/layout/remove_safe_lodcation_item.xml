<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="1">
    <LinearLayout
        android:padding="8dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/card_background"
        android:layout_height="wrap_content"
        android:layout_width="match_parent">

        <!-- Container for Address and Timestamp (Vertical layout) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:orientation="vertical">

            <!-- Address TextView (takes most space) -->
            <TextView
                android:id="@+id/location_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Timestamp TextView (below Address) -->
            <TextView
                android:id="@+id/location_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timestamp"
                android:textSize="12sp"
                android:textColor="#808080" />
        </LinearLayout>

        <!-- "+" Button (fixed size) -->
        <ImageButton
            android:id="@+id/remove_location_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_remove_from_geofence"
            android:contentDescription="Add location"
            android:background="@color/white"/>
    </LinearLayout>
</LinearLayout>